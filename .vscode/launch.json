        // --- C++ Debug ---
        {
            "name": "Attach to R (C++)",
            "type": "cppdbg",
            "request": "attach",
            "program": "/opt/homebrew/bin/R",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
