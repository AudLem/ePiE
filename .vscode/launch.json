{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "R",
            "request": "launch",
            "name": "Debug Current R File",
            "program": "${file}",
            "stopOnEntry": false
        },
        {
            "type": "R",
            "request": "launch",
            "name": "Install ePiE Package",
            "code": "install.packages('/Users/gtazzi/aude/ePiE/Package', repos=NULL, type='source')",
            "stopOnEntry": false
        },
        {
            "type": "R",
            "request": "launch",
            "name": "Run All Regression Tests",
            "code": "library(testthat); library(ePiE); test_dir('Package/tests/testthat', filter='regression')",
            "stopOnEntry": false
        },

        // --- Network Build ---
        {
            "type": "R",
            "request": "launch",
            "name": "Network: Volta Wet (HydroSHEDS)",
